@login_required
def seller_dashboard(request):
    # Books added by this seller
    books = Book.objects.filter(seller=request.user)

    # Orders for seller's books
    orders = Order.objects.filter(book__seller=request.user)

    return render(request, 'books/seller_dashboard.html', {
        'books': books,
        'orders': orders
    })
@login_required
def update_order_status(request, order_id):
    order = Order.objects.get(id=order_id)

    # Only seller can update
    if order.book.seller != request.user:
        return redirect('home')

    if request.method == 'POST':
        status = request.POST.get('status')
        order.status = status
        order.save()

    return redirect('seller_dashboard')
